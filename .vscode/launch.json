{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "run:example",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/flutter_badge_manager/example",
      "args": [],
      "env": {}
    },
    {
      "name": "run:example:android",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/flutter_badge_manager_android/example",
      "args": [],
      "env": {}
    },
    {
      "name": "run:example:ios",
      "type": "dart",
      "request": "launch",
      "cwd": "${workspaceFolder}/flutter_badge_manager_foundation/example",
      "args": [],
      "env": {}
    },
    {
      "name": "run:tests",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/flutter_badge_manager",
      "program": "test/flutter_badge_manager_test.dart",
      "env": {
        "ENVIRONMENT": "test"
      },
      "console": "debugConsole",
      "runTestsOnDevice": false,
      "templateFor": "test",
      "toolArgs": [
        "--file-reporter=json:coverage/tests.json",
        "--color",
        "--concurrency=12",
        "--reporter=expanded",
        "--timeout=30s",
        /* "--name=handles failed connection attempts" */
      ],
      "args": []
    }
  ]
}